// Telegram Mini App Schema
// Для идентификации пользователей и групп в Telegram
// База данных: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Модель пользователя Telegram
model TelegramUser {
  id            String   @id @default(cuid())
  telegramId    Int      @unique // Уникальный ID пользователя в Telegram
  firstName     String?  // Имя пользователя
  lastName      String?  // Фамилия пользователя
  username      String?  // Username пользователя (@username)
  languageCode  String?  // Код языка пользователя
  photoUrl      String?  // URL аватара
  isPremium     Boolean  @default(false) // Премиум статус в Telegram
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Связи
  groups        UserGroup[]
  sessions      UserSession[]

  @@index([telegramId])
}

// Модель группы/канала Telegram
model TelegramGroup {
  id            String   @id @default(cuid())
  telegramId    BigInt   @unique // Уникальный ID группы в Telegram
  title         String?  // Название группы
  type          String?  // Тип: group, supergroup, channel
  username      String?  // Username группы (@username)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Связи
  users         UserGroup[]

  @@index([telegramId])
}

// Связующая таблица пользователей и групп (many-to-many)
model UserGroup {
  id            String   @id @default(cuid())
  userId        String
  groupId       String
  role          String?  @default("member") // Роль: admin, creator, member
  joinedAt      DateTime @default(now())

  // Связи
  user          TelegramUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         TelegramGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

// Сессии пользователей (для отслеживания активных сессий в Mini App)
model UserSession {
  id            String   @id @default(cuid())
  userId        String
  initData      String   // Telegram initData
  chatInstance  String?  // Идентификатор чата/группы
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  // Связи
  user          TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}